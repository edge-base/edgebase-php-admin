{
    "name": "edgebase/admin",
    "description": "EdgeBase Admin SDK — server-side admin operations.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://edgebase.fun/docs/admin-sdk/reference",
    "support": {
        "homepage": "https://edgebase.fun/docs/admin-sdk/reference",
        "issues": "https://github.com/edge-base/edgebase/issues",
        "source": "https://github.com/edge-base/edgebase"
    },
    "autoload": {
        "psr-4": {
            "EdgeBase\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EdgeBase\\Tests\\Admin\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "edgebase/core": "^0.2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "versions": {
                    "edgebase/core": "0.2.6"
                }
            }
        }
    ]
}
